[Unit]
Description=Phantom Browser Automation Agent
Documentation=https://github.com/NinjaTech-AI/phantom
After=network.target supervisor.service
Wants=supervisor.service

[Service]
Type=simple
User=root
WorkingDirectory=/workspace/phantom
ExecStartPre=/bin/sleep 10
ExecStart=/usr/local/bin/python orchestrator.py
Restart=on-failure
RestartSec=30s

Environment=HOME=/root
Environment=DISPLAY=:99
Environment=PYTHONPATH=/workspace
# orchestrator.py owns its own log file: /workspace/logs/phantom_YYYY-MM-DD.log
# systemd captures any pre-logging stdout/stderr (import errors, claude-wrapper
# bleed-through) into the journal — view with: journalctl -u phantom -f
StandardOutput=journal
StandardError=journal
SyslogIdentifier=phantom

[Install]
WantedBy=multi-user.target
